{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtOptions": {
    "Issuer": "IssuerServer",
    "Audience": "AudienceServer",
    "AccessTokenLifetime": "0:30:00",
    "GuestAccessTokenLifetime": "7.00:00:00",
    "RefreshTokenLifetime": "04:00:00"
  },
  "AuthCookies": {
      "AccessTokenCookieName": "access_token",
      "RefreshTokenCookieName": "refresh_token",
      "CookieDomain": "localhost",
      "CookieSameSite": "Lax",
      "Secure": false,
      "HttpOnly": true,
      "RefreshTokenPath": "/api/auth/refresh",
      "GuestAccessTokenExpiry": "7.00:00:00",
      "AccessTokenExpiry": "01:00:00",
      "RefreshTokenExpiry": "04:00:00"
    },
     "Smtp": {
      "Host": "localhost",
      "Port": 25,
      "Username": "",
      "Password": "",
      "FromAddress": "noreply@fasternfaster.local",
      "FromName": "Faster'n'Faster",
      "UseStartTls": false
    },
    "AppUrls" : {
      "FrontendUrl": "http://localhost:3000",
      "BackendUrl": "http://localhost:8080"
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://172.20.10.3:3000",
        "http://10.8.0.5:3000"
      ]
    },
    "RateLimiting": {
      "Enabled": true,
      "Global": { "PermitLimit": 300, "Window": "00:01:00" },
      "AuthStrict": { "PermitLimit": 5, "Window": "00:01:00" },
      "AuthModerate": { "PermitLimit": 10, "Window": "00:01:00" },
      "Lookup": { "PermitLimit": 30, "Window": "00:01:00" }
    },
    "AntiCheat": {
      "SustainedMaxWpm": 300,
      "BurstMaxWpm": 600,
      "AverageWordLength": 5,
      "BurstMinIndexDelta": 15,
      "SustainedCheckMinIndex": 30
    },
    "ResetPassword": {
      "ExpirationTime": "00:15:00"
    },
    "VerifyEmail": {
      "ExpirationTime": "1:00:00"
    },
    "ResendVerification": {
      "Cooldown": "00:00:15"
    },
    "RequestPasswordReset": {
      "Cooldown": "00:00:15"
    },
    "Postgres_User": "test",
    "Postgres_Password": "123456789",
    "Postgres_Db": "faster-n-faster-test"
  }

